# Private key for deploying contracts and sending transactions
# WARNING: Never commit your actual private key! This is just an example.
PRIVATE_KEY=your_private_key_here

# RPC URLs
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Chainlink CCIP Router Addresses
CCIP_ROUTER_FUJI=0xF694E193200268f9a4868e4Aa017A0118C9a8177
CCIP_ROUTER_ARBITRUM_SEPOLIA=0x2a9C5afB0d0e4BAb2BCdaE109EC4b0c4Be15a165

# LINK Token Addresses
LINK_TOKEN_FUJI=0x0b9d5D9136855f6FEc3c0993feE6E9CE8a297846
LINK_TOKEN_ARBITRUM_SEPOLIA=0xb1D4538B4571d411F07960EF2838Ce337FE1E80E

# Chain Selectors
FUJI_CHAIN_SELECTOR=14767482510784806043
ARBITRUM_SEPOLIA_CHAIN_SELECTOR=3478487238524512106

# Deployed Contract Addresses (populate after deployment)
FUJI_NFT_ADDRESS=
FUJI_BRIDGE_ADDRESS=
ARBITRUM_SEPOLIA_NFT_ADDRESS=
ARBITRUM_SEPOLIA_BRIDGE_ADDRESS=

# Optional: Block explorer API keys for contract verification
SNOWTRACE_API_KEY=your_snowtrace_api_key_here
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# Network for deployment scripts
NETWORK=fuji
